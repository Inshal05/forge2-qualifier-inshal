{
  "name": "forge2/kanban-api",
  "description": "Laravel REST API skeleton for the Forge 2 qualifier Kanban board.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0 || ^12.0",
    "laravel/sanctum": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
